# SFE OPS 환경 변수 템플릿
# 이 파일을 복사해서 .env 파일로 사용하세요: cp .env.example .env
# .env 파일은 절대 git에 커밋하지 마세요.

# ────────────────────────────────────────
# Supabase 연결 정보
# ────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ────────────────────────────────────────
# OPS Core API 설정
# ────────────────────────────────────────
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8000
OPS_ENV=development

# ────────────────────────────────────────
# 데이터 경로 설정
# ────────────────────────────────────────
# 로컬 기준 데이터 저장 경로
DATA_DIR=./data
FIXTURE_DIR=./tests/fixtures

# ────────────────────────────────────────
# Streamlit 콘솔 설정
# ────────────────────────────────────────
STREAMLIT_PORT=8501
